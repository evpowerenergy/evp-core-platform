# =============================================================================
# EV Power Energy CRM - Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your values. Never commit .env.local
# to version control.
#
#   cp .env.example .env.local
#
# =============================================================================

# -----------------------------------------------------------------------------
# Required (Client – used by frontend build)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------------------------------------------
# Required for server-side only (e.g. Vercel API routes, keep-alive)
# Set in Vercel Dashboard → Settings → Environment Variables
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# -----------------------------------------------------------------------------
# Optional – App metadata (client-safe)
# -----------------------------------------------------------------------------
# VITE_APP_NAME=EV Power Energy CRM
# VITE_APP_VERSION=1.0.0
# VITE_DEV_MODE=development

# -----------------------------------------------------------------------------
# Optional – Facebook / Google Ads (server-side only for production)
# -----------------------------------------------------------------------------
# For production, do NOT use VITE_* for tokens/secrets. Use server-side env
# (e.g. Edge Functions, Vercel serverless) and proxy APIs. See docs/ENV_AND_ADS.md
#
# Local/dev only (not recommended for production):
# VITE_FACEBOOK_ACCESS_TOKEN=
# VITE_FACEBOOK_PAGE_ACCESS_TOKEN=
# VITE_FACEBOOK_AD_ACCOUNT_ID=
# VITE_FACEBOOK_AD_ACCOUNT_IDS=1234567890,0987654321
# VITE_FACEBOOK_AD_ACCOUNTS=[{"adAccountId":"1234567890","accessToken":"EAAB..."},{"adAccountId":"0987654321","accessToken":"EAAB..."}]
# VITE_FACEBOOK_PAGE_ID=
# VITE_FACEBOOK_PAGES=
# VITE_FACEBOOK_APP_ID=
# VITE_FACEBOOK_APP_SECRET=
# Server-side/Edge Function multi-account (production/local API testing):
# FACEBOOK_ACCESS_TOKEN=EAAB...
# FACEBOOK_AD_ACCOUNT_IDS=1234567890,0987654321
# FACEBOOK_AD_ACCOUNTS=[{"adAccountId":"1234567890","accessToken":"EAAB..."},{"adAccountId":"0987654321","accessToken":"EAAB..."}]
# VITE_GOOGLE_ADS_DEVELOPER_TOKEN=
# VITE_GOOGLE_ADS_CLIENT_ID=
# VITE_GOOGLE_ADS_CLIENT_SECRET=
# VITE_GOOGLE_ADS_REFRESH_TOKEN=
# VITE_GOOGLE_ADS_CUSTOMER_ID=
