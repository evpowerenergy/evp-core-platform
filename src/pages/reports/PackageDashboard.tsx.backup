            <CardHeader className="pb-1">
              <CardTitle className="text-sm">เมตริกเพิ่มเติม</CardTitle>
            </CardHeader>
            <CardContent className="space-y-2 py-2">
               <div className="flex flex-col gap-2">
                <div 
